# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Frontend API target.
# Leave empty to use the same origin, or set it to a full backend URL such as http://43.205.214.197:3002
VITE_API_BASE_URL=""

# Comma-separated list of browser origins allowed to call this server.
# Use * to allow any origin, or specify exact origins like https://wormlike-loren-harmoniously.ngrok-free.dev
ALLOWED_ORIGINS="*"

# Database Configuration
DB_USER=postgres
DB_HOST=family-tree-db.cuafddu82hzq.ap-south-1.rds.amazonaws.com
DB_NAME=page_builder_app
DB_PASSWORD=v4HmYtmNgvsVkRrB81AT
DB_PORT=5432


# Constructed Database URL
DATABASE_URL="postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}?schema=public"
