generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Page {
  id               String            @id @default(uuid())
  name             String
  slug             String            @unique
  status           String            @default("draft")
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  customerId       String?
  logo             String?
  additionalData   String?
  collectionGroups CollectionGroup[]
  customer         Customer?         @relation(fields: [customerId], references: [id], onDelete: Cascade)
}

model CollectionGroup {
  id              String       @id @default(uuid())
  name            String
  style           String
  backgroundImage String?
  reference       String?
  additionalData  String?
  status          String       @default("draft")
  order           Int          @default(0)
  pageId          String
  collections     Collection[]
  page            Page         @relation(fields: [pageId], references: [id], onDelete: Cascade)
}

model Collection {
  id                String           @id @default(uuid())
  name              String
  link              String?
  shopifyId         String?
  collectionType    String?
  isScrollable      Boolean          @default(false)
  style             String
  horizontal        Boolean          @default(false)
  additionalData    String?
  navigation        String?
  image             String?
  column            Int?
  button            String?
  collectionFilters String?
  status            String           @default("draft")
  order             Int              @default(0)
  groupId           String
  group             CollectionGroup  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  items             CollectionItem[]
}

model CollectionItem {
  id             String     @id @default(uuid())
  name           String
  images         String?
  text1          String?
  text2          String?
  text3          String?
  link           String?
  shopifyId      String?
  style          String
  media          String?
  additionalData String?
  reference      String?
  navigation     String?
  button         String?
  status         String     @default("draft")
  order          Int        @default(0)
  collectionId   String
  collection     Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
}

model GlobalSetting {
  id                        String  @id @default(uuid())
  offers                    String?
  bestSellerTag             String?
  newArrivalTag             String?
  sellingFastTag            String?
  bigSaveBasedOnValue       String?
  productLabelTheme         String?
  wishlist                  Boolean @default(true)
  productDetailTag          String?
  tagPriority               String?
  sellingFastQTY            Int?
  appForceUpdateVersion     String?
  appNewVersion             String?
  androidForceUpdateVersion String?
  androidNewVersion         String?
  iosForceUpdateVersion     String?
  iosNewVersion             String?
}

model GlobalStyle {
  id        String @id @default(uuid())
  styleList String
}

model Store {
  id            String    @id @default(uuid())
  name          String
  address       String?
  contactUs     String?
  direction     String?
  latitude      Float?
  longitude     Float?
  city          String?
  state         String?
  image         String?
  rating        Float?
  ratingUser    Int?
  openingTime   String?
  closingTime   String?
  storePosition Int       @default(0)
  isPopular     Boolean   @default(false)
  status        String    @default("published")
  customerId    String?
  customer      Customer? @relation(fields: [customerId], references: [id], onDelete: Cascade)
}

model ProductColor {
  id         String    @id @default(uuid())
  colorName  String
  colorCode  String?
  imageUrl   String?
  imageName  String?
  colorType  String    @default("Color")
  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: Cascade)
}

model Media {
  id         String    @id @default(uuid())
  url        String
  name       String
  size       Int?
  type       String?
  createdAt  DateTime  @default(now())
  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: Cascade)
}

model HomeShopPage {
  id   String @id @default(uuid())
  data String
}

model Customer {
  id            String         @id @default(uuid())
  email         String         @unique
  password      String
  name          String
  role          String         @default("customer")
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  lastLogin     DateTime?
  phone         String?
  status        String         @default("active")
  media         Media[]
  pages         Page[]
  productColors ProductColor[]
  stores        Store[]
}
